# --- SERVIDOR ---
PORT=5000
NODE_ENV=development

# --- BASE DE DATOS (PostgreSQL) ---
# Cambia 'tu_password_aqui' por la contraseña de tu usuario postgres
DB_HOST=localhost
DB_PORT=5432
DB_NAME=quinta_ines_maria
DB_USER=postgres
DB_PASSWORD=

# --- AUTENTICACIÓN (JWT) ---
# Puedes poner cualquier frase larga para la seguridad
JWT_SECRET=
JWT_EXPIRES_IN=7d

# --- GOOGLE GEMINI AI ---
# Pega aquí la clave que copiaste de Google AI Studio (AIzaSy...)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# --- CORS ---
FRONTEND_URL=http://localhost:5173